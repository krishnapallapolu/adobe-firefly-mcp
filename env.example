# =============================================================================
#  adobe-firefly-mcp — environment variables
#  Copy this file to `.env` and fill in the values below.
# =============================================================================

# -----------------------------------------------------------------------------
#  MOCK MODE — local dev without Adobe credentials
# -----------------------------------------------------------------------------
# Set to "true" to bypass Adobe entirely and return placeholder images from
# picsum.photos. Useful for local dev, demos, and contributing without an
# enterprise ETLA. When true, FIREFLY_CLIENT_ID and FIREFLY_CLIENT_SECRET are
# ignored. Default: false.
FIREFLY_MOCK=false

# -----------------------------------------------------------------------------
#  Adobe Firefly Services credentials
# -----------------------------------------------------------------------------
# Required UNLESS FIREFLY_MOCK=true.
# Obtain from https://developer.adobe.com/console (enterprise ETLA required).
FIREFLY_CLIENT_ID=
FIREFLY_CLIENT_SECRET=

# -----------------------------------------------------------------------------
#  MCP bearer token — HTTP transport only
# -----------------------------------------------------------------------------
# Shared secret between this server and the MCP client. Must be at least 32
# characters. Not used when running via stdio transport (npm run dev:stdio).
# Generate one with:   openssl rand -hex 32
MCP_BEARER_TOKEN=

# -----------------------------------------------------------------------------
#  Server (optional)
# -----------------------------------------------------------------------------
PORT=6002
HOST=0.0.0.0
LOG_LEVEL=info

# -----------------------------------------------------------------------------
#  Firefly job polling (optional — defaults are reasonable)
# -----------------------------------------------------------------------------
POLL_INTERVAL_MS=1500
POLL_TIMEOUT_MS=180000
