# Adobe Firefly Services credentials — Adobe Developer Console
FIREFLY_CLIENT_ID=replace-me
FIREFLY_CLIENT_SECRET=replace-me

# Bearer token Cowork will send to authenticate.
# Generate with:  openssl rand -hex 32
MCP_BEARER_TOKEN=replace-me-min-32-chars

# Optional
LOG_LEVEL=info
PORT=6002
HOST=0.0.0.0
POLL_INTERVAL_MS=1500
POLL_TIMEOUT_MS=180000
